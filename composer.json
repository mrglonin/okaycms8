    "require": {
        "php": "^8.5",
        "ext-SimpleXML": "*",
        "ext-XMLReader": "*",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-mbstring": "*",
        "ext-zip": "*",
        "gregwar/image": "2.*",
        "smarty/smarty": "^5.8",
        "mobiledetect/mobiledetectlib": "^4.8",
        "phpmailer/phpmailer": "^7.0",
        "sabberworm/php-css-parser": "^9.3",
        "matthiasmullie/minify": "^1.3.75",
        "bramus/router": "^1.6.1",
        "psr/log": "^3.0",
        "monolog/monolog": "^3.10",
        "aura/sqlquery": "^3",
        "aura/sql": "^6",
        "haydenpierce/class-finder": "^0.5.3",
        "axy/sourcemap": "^1.1",
        "snowplow/referer-parser": "^0.2.0",
        "giggsey/libphonenumber-for-php": "^9.0",
        "rosell-dk/webp-convert": "^2.9.3",
        "psr/container": "^2.0",
        "symfony/console": "^8.0",
        "dragonmantank/cron-expression": "^3.6",
        "symfony/process": "^8.0",
        "symfony/lock": "^8.0",
        "orhanerday/open-ai": "^5.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "php-debugbar/php-debugbar": "^3.5",
        "symfony/var-dumper": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Okay\\": "Okay/",
            "Okay\\Admin\\": "backend/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php -r \"file_exists('./config/config.local.php') || copy('./config/config.php', './config/config.local.php');\"",
            "@php ok database:deploy"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
